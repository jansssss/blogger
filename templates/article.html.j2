<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$title</title>
</head>
<body>
<div class="hb-post">
<style>
.hb-post {
  font-family: "Apple SD Gothic Neo", "Malgun Gothic", "Segoe UI", sans-serif;
  color: #1c2741;
  line-height: 1.8;
  max-width: 720px;
  margin: 0 auto;
  padding: 0 16px 48px;
  word-break: keep-all;
}
.hb-post * { box-sizing: border-box; }

/* 상단 헤더 */
.hb-header {
  border-top: 4px solid #ff6b57;
  padding: 32px 0 24px;
}
.hb-badge {
  display: inline-block;
  background: #ff6b57;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 999px;
  margin-bottom: 14px;
}
.hb-theme {
  display: inline-block;
  color: #3268ff;
  font-size: 13px;
  font-weight: 600;
  margin-left: 8px;
}
.hb-post h1 {
  margin: 0 0 12px;
  font-size: clamp(22px, 5vw, 34px);
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.02em;
  color: #1c2741;
}
.hb-subtitle {
  font-size: 16px;
  color: #5a6a85;
  margin: 0 0 14px;
  line-height: 1.6;
}
.hb-meta {
  font-size: 13px;
  color: #9aa5b8;
}

/* 핵심 요약 카드 */
.hb-summary {
  background: #f4f7ff;
  border-left: 4px solid #3268ff;
  border-radius: 0 12px 12px 0;
  padding: 20px 20px 16px;
  margin: 28px 0;
}
.hb-summary-title {
  font-size: 15px;
  font-weight: 700;
  color: #3268ff;
  margin: 0 0 14px;
  letter-spacing: 0.01em;
}
.hb-summary ol {
  margin: 0;
  padding-left: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.hb-summary li {
  font-size: 15px;
  color: #2a3a5c;
  line-height: 1.6;
}

/* 본문 섹션 */
.hb-post h2 {
  font-size: clamp(18px, 4vw, 24px);
  font-weight: 800;
  color: #1c2741;
  margin: 36px 0 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #eef2f7;
  letter-spacing: -0.02em;
  line-height: 1.4;
}
.hb-post p {
  font-size: 16px;
  color: #3a4a62;
  margin: 0 0 14px;
  line-height: 1.85;
}

/* 실천 포인트 & 키워드 칩 */
.hb-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 12px 0 4px;
}
.hb-chip {
  display: inline-block;
  padding: 6px 14px;
  border-radius: 999px;
  background: #fff;
  border: 1.5px solid #d0daea;
  color: #4a5a78;
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
}
.hb-section-tips .hb-chip { border-color: #ffcfc9; color: #cc3a28; }
.hb-section-tags .hb-chip { border-color: #bdd0ff; color: #2652cc; }

/* 면책 고지 */
.hb-notice {
  margin-top: 32px;
  padding: 16px 18px;
  border-radius: 10px;
  background: #fffbef;
  border: 1px solid #f0e08a;
  font-size: 13px;
  color: #6b5b1a;
  line-height: 1.7;
}

@media (max-width: 480px) {
  .hb-post { padding: 0 12px 36px; }
  .hb-header { padding: 24px 0 18px; }
  .hb-summary { padding: 16px 14px 12px; }
  .hb-post h2 { margin-top: 28px; }
}
</style>

  <div class="hb-header">
    <span class="hb-badge">건강 정보</span><span class="hb-theme">$theme</span>
    <h1>$title</h1>
    <p class="hb-subtitle">$subtitle</p>
    <div class="hb-meta">$published_label &nbsp;·&nbsp; 업데이트 $updated_label</div>
  </div>

  <div class="hb-summary">
    <div class="hb-summary-title">이 글의 핵심 요약</div>
    <ol>
      $summary_items
    </ol>
  </div>

  $section_items

  <div class="hb-section-tips">
    <h2>실천 포인트</h2>
    <div class="hb-chips">$tip_items</div>
  </div>

  <div class="hb-section-tags">
    <h2>관련 키워드</h2>
    <div class="hb-chips">$tag_items</div>
  </div>

  <div class="hb-notice">$disclaimer</div>

</div>
</body>
</html>
